[alias]
	graph = log --graph --oneline
	ls-ignored = ls-files --others --ignored --exclude-standard --directory
[blame]
	coloring = repeatedLines
[commit]
	gpgsign = true
[core]
	editor = nvim
	hooksPath = .githooks
	pager = delta
	sshCommand = ssh -i ~/.ssh/psychokadse@github.com_ed25519 -o IdentitiesOnly=yes
[credential "https://github.com/psychokadse"]
	username = psychokadse
[delta]
	line-numbers = true
	side-by-side = true
	navigate = true
[diff]
	tool = nvimdiff
[difftool]
	prompt = false
[fetch]
	prune = true
	pruneTags = true
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only
[merge]
	tool = nvimmerge
	conflictStyle = zdiff3
[mergetool]
	keepBackup = false
	prompt = false
[mergetool "nvimmerge"]
	cmd = nvim -d "$MERGED" "$LOCAL" "$BASE" "$REMOTE"
	trustExitCode = false
[rerere]
	enabled = true
[user]
	name = psychokadse
	email = psyccvx42kits@proton.me
	signingkey = psyccvx42kits@proton.me
[includeIf "gitdir:~/Documents/dev/work/"]
	path = ./config.work
