# i3blocks configuration file
#
# The i3blocks man page describes the usage of the binary,
# and its website describes the configuration:
#
#     https://vivien.github.io/i3blocks


# Global properties
_color_urgent=#FF0000
_color_warn=#F0F000
separator=true
separator_block_width=15

[fixme]
color=#D08000
full_text=Please get this working >

[ethernet]
full_text=ethernet _first_

[disk]
full_text=disk "/"

[cpu_usage]
full_text=cpu_usage

[memory]
full_text=memory

[volume master]
_color_muted=#808000
_color_urgent=#FF0000
command=./volume.sh
interval=persist
markup=pango

[keyboard]
color=#4088FF
command=echo "<b>$(xkb-switch)</b>"
interval=once
markup=pango
signal=10

[time]
command=date '+<b>%F %r</b>'
interval=1
markup=pango
