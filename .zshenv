export ZDOTDIR="${HOME}/.config/zsh"
export ZSH_COMPDUMP="${ZDOTDIR}/.zcompdump"
export PATH="${PATH}:${HOME}/.local/share/JetBrains/Toolbox/bin:${HOME}/.local/share/JetBrains/Toolbox/scripts"
export TERMINAL=wezterm

if [[ $USERNAME == slthns ]]; then
	WM_WALLPAPER=~/Pictures/wallpapers/wallpapersden.com_spirited-away-6k_1920x1080.jpg
else
	WM_WALLPAPER=~/Pictures/wallpapers/wallpapersden.com_anime-girl-hd-sunrise-2022_1920x1080.jpg
fi

export WM_WALLPAPER
