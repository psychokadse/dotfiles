[alias]
	graph = log --graph --oneline
[blame]
	coloring = repeatedLines
[commit]
	gpgsign = true
[core]
	editor = nvim
	hooksPath = .githooks
	pager = less
[credential "https://github.com/psychokadse"]
	username = psychokadse
[credential "https://github.com/pkerschbaumer"]
	username = pkerschbaumer
[diff]
	tool = nvimdiff
[difftool]
	prompt = false
[fetch]
	prune = true
	pruneTags = true
[init]
	defaultBranch = main
[merge]
	tool = nvimmerge
[mergetool]
	keepBackup = false
	prompt = false
[mergetool "nvimmerge"]
	cmd = nvim -d "$MERGED" "$LOCAL" "$BASE" "$REMOTE"
	trustExitCode = false
[rerere]
	enabled = true
[user]
	name = pkerschbaumer
	email = paul.kerschbaumer@ausbildung-bbw.de
	signingkey = paul.kerschbaumer@ausbildung-bbw.de
