[submodule "src/.config/zsh/plugins/fast-syntax-highlighting"]
	path = src/local/.config/zsh/plugins/fast-syntax-highlighting
	url = https://github.com/zdharma-continuum/fast-syntax-highlighting.git
	branch = master
[submodule "src/.config/zsh/plugins/zsh-autocomplete"]
	path = src/local/.config/zsh/plugins/zsh-autocomplete
	url = https://github.com/marlonrichert/zsh-autocomplete.git
	branch = main
[submodule "src/.config/zsh/plugins/zsh-autosuggestions"]
	path = src/local/.config/zsh/plugins/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions.git
	branch = master
[submodule "src/.config/zsh/plugins/zsh-completions"]
	path = src/local/.config/zsh/plugins/zsh-completions
	url = https://github.com/zsh-users/zsh-completions.git
	branch = master
[submodule "src/.config/zsh/themes/powerlevel10k"]
	path = src/local/.config/zsh/themes/powerlevel10k
	url = https://github.com/romkatv/powerlevel10k.git
	branch = master
[submodule "src/.config/tmux/tmux-sessionizer"]
	path = src/local/.config/tmux/tmux-sessionizer
	url = https://github.com/ThePrimeagen/tmux-sessionizer.git
[submodule "src/local/.config/tmux/plugins/tpm"]
	path = src/local/.config/tmux/plugins/tpm
	url = https://github.com/tmux-plugins/tpm
