# i3blocks configuration file
#
# The i3blocks man page describes the usage of the binary,
# and its website describes the configuration:
#
#     https://vivien.github.io/i3blocks


# Global properties
_color_urgent=#FF0000
_color_warn=#F0F000
command=$SCRIPT_DIR/$BLOCK_NAME
markup=pango
separator=true
separator_block_width=15

[ethernet]
interval=1

[disk]
interval=4

[cpu_usage]
interval=1

[memory]
interval=2

[volume]
interval=persist

[keyboard]
color=#4088FF
command=echo "<b>$(xkb-switch)</b>"
interval=once
signal=10

[time]
command=date '+%F %r'
interval=1
